---
import '../styles/global.css';
import { env } from 'cloudflare:workers';
import { getSession } from '../lib/auth';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Send party invites by email or text. Track RSVPs instantly. No accounts needed.' } = Astro.props;

const sessionToken = Astro.cookies.get('wid_session')?.value;
let currentUser = null;
if (sessionToken) {
  try { currentUser = await getSession(env.SESSION, sessionToken); } catch {}
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="bg-white text-zinc-900 font-sans antialiased">

  <nav class="bg-zinc-950 sticky top-0 z-50 border-b border-white/5 backdrop-blur">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="text-white font-extrabold text-base tracking-tight hover:text-violet-300 transition-colors">
        whosisdown
      </a>
      <div class="flex items-center gap-3">
        <a href="/party/new" class="bg-violet-600 hover:bg-violet-700 text-white text-sm font-semibold px-4 py-1.5 rounded-md transition-colors">
          Create party
        </a>
        {currentUser ? (
          <div class="flex items-center gap-2">
            <span class="text-zinc-400 text-sm hidden sm:block">{currentUser.username}</span>
            <button id="logout-btn" class="text-zinc-500 hover:text-white text-xs transition-colors">Sign out</button>
          </div>
        ) : (
          <a href="/login" class="text-zinc-400 hover:text-white text-sm transition-colors">Sign in</a>
        )}
      </div>
    </div>
  </nav>

  <slot />

  <script>
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/';
    });
  </script>

  <footer class="border-t border-zinc-100 mt-24">
    <div class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-between text-sm text-zinc-400">
      <span>whosisdown.com</span>
      <div class="flex gap-6">
        <a href="https://github.com/pablocaminog/evite-os" class="hover:text-zinc-600 transition-colors">Open source</a>
        <span>Built on Cloudflare</span>
      </div>
    </div>
  </footer>

</body>
</html>
