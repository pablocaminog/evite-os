---
export const prerender = false;
import { getPartyByManagementToken, getGuestsByPartyId, getRsvpSummary, consumeMagicLink } from '../../lib/db';
import GuestTable from '../../components/GuestTable.astro';
import InviteForm from '../../components/InviteForm.astro';

const { token } = Astro.params;
const { env } = Astro.locals.runtime;

const ml = Astro.url.searchParams.get('ml');
if (ml) {
  await consumeMagicLink(env.DB, ml);
  return Astro.redirect(`/manage/${token}`);
}

const party = await getPartyByManagementToken(env.DB, token!);
if (!party) return Astro.redirect('/');

const [guests, summary] = await Promise.all([
  getGuestsByPartyId(env.DB, party.id),
  getRsvpSummary(env.DB, party.id),
]);

const imageUrl = party.image_key ? `${env.APP_URL}/images/${party.id}/cover` : null;
const eventDate = new Date(party.event_date).toLocaleDateString('en-US', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
  timeZone: 'UTC',
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{party.title} — Dashboard</title>
  <style>
    body { font-family: system-ui, sans-serif; background: #f8f9fa; min-height: 100vh; }
    .hero { background: linear-gradient(135deg, #6366f1, #8b5cf6); padding: 40px 24px; color: white; position: relative; overflow: hidden; min-height: 160px; }
    .hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: .25; }
    .hero-content { position: relative; max-width: 860px; margin: 0 auto; }
    .hero h1 { font-size: 2rem; margin-bottom: 8px; }
    .hero .meta { opacity: .85; font-size: 15px; }
    .container { max-width: 900px; margin: 0 auto; padding: 32px 24px; }
    nav { padding: 12px 24px; background: white; box-shadow: 0 1px 0 #eee; display: flex; justify-content: space-between; align-items: center; }
    nav a { color: #6366f1; text-decoration: none; font-weight: 600; font-size: 15px; }
    .upload-label { cursor: pointer; color: rgba(255,255,255,.8); font-size: 13px; border: 1px solid rgba(255,255,255,.4); border-radius: 6px; padding: 4px 10px; margin-top: 12px; display: inline-block; }
    #img-input { display: none; }
  </style>
</head>
<body>
  <nav>
    <a href="/">← evite-os</a>
    <a href="/magic-link">Recover link by email</a>
  </nav>

  <div class="hero">
    {imageUrl && <img src={imageUrl} class="hero-img" alt="" />}
    <div class="hero-content">
      <h1>{party.title}</h1>
      <p class="meta">{eventDate}{party.location ? ` · ${party.location}` : ''}</p>
      {party.description && <p class="meta" style="margin-top:6px">{party.description}</p>}
      <label class="upload-label" for="img-input">
        {imageUrl ? '🖼 Change cover image' : '🖼 Add cover image'}
      </label>
      <input type="file" id="img-input" accept="image/jpeg,image/png,image/webp" />
    </div>
  </div>

  <div class="container">
    <GuestTable guests={guests} summary={summary} partyId={party.id} managementToken={token!} appUrl={env.APP_URL} />
    <InviteForm partyId={party.id} managementToken={token!} />
  </div>

  <script define:vars={{ partyId: party.id, managementToken: token }}>
    document.getElementById('img-input').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      await fetch('/api/upload', {
        method: 'POST',
        headers: { 'X-Management-Token': managementToken, 'X-Party-Id': partyId, 'Content-Type': file.type },
        body: await file.arrayBuffer(),
      });
      location.reload();
    });
  </script>
</body>
</html>
