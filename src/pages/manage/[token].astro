---
export const prerender = false;
import { getPartyByManagementToken, getGuestsByPartyId, getRsvpSummary, consumeMagicLink } from '../../lib/db';
import Layout from '../../layouts/Layout.astro';
import GuestTable from '../../components/GuestTable.astro';
import InviteForm from '../../components/InviteForm.astro';

const { token } = Astro.params;
const { env } = Astro.locals.runtime;

const ml = Astro.url.searchParams.get('ml');
if (ml) {
  await consumeMagicLink(env.DB, ml);
  return Astro.redirect(`/manage/${token}`);
}

const party = await getPartyByManagementToken(env.DB, token!);
if (!party) return Astro.redirect('/');

const [guests, summary] = await Promise.all([
  getGuestsByPartyId(env.DB, party.id),
  getRsvpSummary(env.DB, party.id),
]);

const imageUrl = party.image_key ? `${env.APP_URL}/images/${party.id}/cover` : null;
const eventDate = new Date(party.event_date).toLocaleDateString('en-US', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
  timeZone: 'UTC',
});
---

<Layout title={`${party.title} — Dashboard`}>

  <!-- Hero banner -->
  <div class="relative bg-zinc-950 overflow-hidden min-h-[180px] flex items-end">
    {imageUrl && (
      <img src={imageUrl} alt="" class="absolute inset-0 w-full h-full object-cover opacity-20" />
    )}
    <div class="relative max-w-5xl mx-auto px-6 pb-8 pt-12 w-full">
      <p class="text-violet-400 text-[12px] font-semibold uppercase tracking-widest mb-1">Your party dashboard</p>
      <h1 class="text-white text-3xl font-extrabold tracking-tight mb-1">{party.title}</h1>
      <p class="text-zinc-400 text-sm">{eventDate}{party.location ? ` · ${party.location}` : ''}</p>
      {party.description && <p class="text-zinc-500 text-sm mt-1">{party.description}</p>}

      <div class="mt-4 flex gap-3 items-center flex-wrap">
        <label for="img-input"
          class="cursor-pointer border border-white/20 hover:border-white/40 text-white/70 hover:text-white text-xs font-medium px-3 py-1.5 rounded-md transition-colors">
          {imageUrl ? '🖼 Change cover' : '🖼 Add cover image'}
        </label>
        <a href="/magic-link"
           class="text-zinc-500 hover:text-zinc-300 text-xs transition-colors">
          Recover link by email →
        </a>
        <input type="file" id="img-input" accept="image/jpeg,image/png,image/webp" class="hidden" />
      </div>
    </div>
  </div>

  <!-- Main content -->
  <div class="max-w-5xl mx-auto px-6 py-10">
    <GuestTable guests={guests} summary={summary} partyId={party.id} managementToken={token!} appUrl={env.APP_URL} />
    <InviteForm partyId={party.id} managementToken={token!} />
  </div>

</Layout>

<script define:vars={{ partyId: party.id, managementToken: token }}>
  document.getElementById('img-input').addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    await fetch('/api/upload', {
      method: 'POST',
      headers: { 'X-Management-Token': managementToken, 'X-Party-Id': partyId, 'Content-Type': file.type },
      body: await file.arrayBuffer(),
    });
    location.reload();
  });
</script>
