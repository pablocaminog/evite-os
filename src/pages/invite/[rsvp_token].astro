---
export const prerender = false;
import { getGuestByRsvpToken, getPartyById } from '../../lib/db';
import RsvpForm from '../../components/RsvpForm.astro';

const { rsvp_token } = Astro.params;
const { env } = Astro.locals.runtime;

const guest = await getGuestByRsvpToken(env.DB, rsvp_token!);
if (!guest) return Astro.redirect('/');

const party = await getPartyById(env.DB, guest.party_id);
if (!party) return Astro.redirect('/');

const imageUrl = party.image_key ? `${env.APP_URL}/images/${party.id}/cover` : null;
const eventDate = new Date(party.event_date).toLocaleDateString('en-US', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
  hour: 'numeric', minute: '2-digit', timeZone: 'UTC',
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>You're invited to {party.title}!</title>
  <style>
    body { font-family: system-ui, sans-serif; background: #f8f9fa; min-height: 100vh; }
    .cover { width: 100%; max-height: 320px; object-fit: cover; display: block; }
    .container { max-width: 560px; margin: 0 auto; padding: 32px 24px; }
    .party-card { background: white; border-radius: 16px; padding: 28px; box-shadow: 0 2px 12px rgba(0,0,0,.07); margin-bottom: 24px; }
    .party-card h1 { font-size: 1.75rem; margin-bottom: 16px; }
    .meta { display: flex; flex-direction: column; gap: 8px; color: #555; }
    .meta-row { display: flex; gap: 10px; align-items: flex-start; font-size: 15px; }
    .icon { font-size: 18px; flex-shrink: 0; }
    footer { text-align: center; padding: 24px; color: #bbb; font-size: 13px; }
    footer a { color: #bbb; }
  </style>
</head>
<body>
  {imageUrl && <img src={imageUrl} class="cover" alt={`${party.title} cover`} />}
  <div class="container">
    <div class="party-card">
      <h1>{party.title}</h1>
      <div class="meta">
        <div class="meta-row"><span class="icon">📅</span>{eventDate}</div>
        {party.location && <div class="meta-row"><span class="icon">📍</span>{party.location}</div>}
        {party.description && <div class="meta-row"><span class="icon">💬</span>{party.description}</div>}
        <div class="meta-row"><span class="icon">👤</span>From {party.organizer_name}</div>
      </div>
    </div>
    <RsvpForm
      guestName={guest.name}
      rsvpToken={rsvp_token!}
      currentStatus={guest.status}
      currentCount={guest.guest_count}
      currentNotes={guest.dietary_notes}
    />
  </div>
  <footer>Powered by <a href="https://github.com/evite-os/evite-os">evite-os</a></footer>
</body>
</html>
