---
export const prerender = false;
import { getGuestByRsvpToken, getPartyById } from '../../lib/db';
import Layout from '../../layouts/Layout.astro';
import RsvpForm from '../../components/RsvpForm.astro';

const { rsvp_token } = Astro.params;
const { env } = Astro.locals.runtime;

const guest = await getGuestByRsvpToken(env.DB, rsvp_token!);
if (!guest) return Astro.redirect('/');

const party = await getPartyById(env.DB, guest.party_id);
if (!party) return Astro.redirect('/');

const imageUrl = party.image_key ? `${env.APP_URL}/images/${party.id}/cover` : null;
const eventDate = new Date(party.event_date).toLocaleDateString('en-US', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
  hour: 'numeric', minute: '2-digit', timeZone: 'UTC',
});
---

<Layout title={`You're invited to ${party.title}!`} description={`${party.organizer_name} invited you to ${party.title}. RSVP now.`}>

  <!-- Cover image -->
  {imageUrl && (
    <div class="w-full h-56 sm:h-72 overflow-hidden relative">
      <img src={imageUrl} alt={`${party.title} cover`}
           class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
    </div>
  )}

  <div class="max-w-lg mx-auto px-6 py-10 flex flex-col gap-5">

    <!-- Party card -->
    <div class="bg-white rounded-2xl border border-zinc-100 shadow-sm px-6 py-6">
      <p class="text-[12px] font-semibold tracking-widest uppercase text-violet-600 mb-2">
        {party.organizer_name} invites you
      </p>
      <h1 class="text-2xl font-extrabold tracking-tight text-zinc-900 mb-4">{party.title}</h1>
      <ul class="flex flex-col gap-2.5">
        <li class="flex items-start gap-3 text-sm text-zinc-600">
          <span class="text-base mt-px">📅</span>
          <span>{eventDate}</span>
        </li>
        {party.location && (
          <li class="flex items-start gap-3 text-sm text-zinc-600">
            <span class="text-base mt-px">📍</span>
            <span>{party.location}</span>
          </li>
        )}
        {party.description && (
          <li class="flex items-start gap-3 text-sm text-zinc-600">
            <span class="text-base mt-px">💬</span>
            <span>{party.description}</span>
          </li>
        )}
      </ul>
    </div>

    <!-- RSVP form -->
    <RsvpForm
      guestName={guest.name}
      rsvpToken={rsvp_token!}
      currentStatus={guest.status}
      currentCount={guest.guest_count}
      currentNotes={guest.dietary_notes}
    />

  </div>
</Layout>
