---
export const prerender = false;
import { env } from 'cloudflare:workers';
import Layout from '../layouts/Layout.astro';
import { getSession } from '../lib/auth';
import { getPartiesByUserId, getRsvpSummary } from '../lib/db';

const sessionToken = Astro.cookies.get('wid_session')?.value;
if (!sessionToken) return Astro.redirect('/login?redirect=/my-parties');

const session = await getSession(env.SESSION, sessionToken);
if (!session) return Astro.redirect('/login?redirect=/my-parties');

const parties = await getPartiesByUserId(env.DB, session.userId);

// Fetch RSVP summary for each party in parallel
const summaries = await Promise.all(
  parties.map(p => getRsvpSummary(env.DB, p.id))
);

const eventDateFmt = (d: string) =>
  new Date(d).toLocaleDateString('en-US', {
    weekday: 'short', month: 'short', day: 'numeric',
    year: 'numeric', timeZone: 'UTC',
  });
---

<Layout title="My parties — whosisdown">
  <div class="max-w-3xl mx-auto px-6 py-14">

    <div class="flex items-center justify-between mb-10">
      <div>
        <h1 class="text-2xl font-extrabold tracking-tight text-zinc-900">My parties</h1>
        <p class="text-sm text-zinc-500 mt-0.5">Signed in as <span class="font-semibold text-zinc-700">{session.username}</span></p>
      </div>
      <a href="/party/new"
        class="bg-violet-600 hover:bg-violet-700 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors">
        + New party
      </a>
    </div>

    {parties.length === 0 ? (
      <div class="bg-white border border-zinc-100 rounded-2xl px-8 py-16 text-center shadow-sm">
        <div class="text-4xl mb-4">🎉</div>
        <h2 class="text-lg font-bold text-zinc-800 mb-2">No parties yet</h2>
        <p class="text-sm text-zinc-500 mb-6">Create your first party and start collecting RSVPs.</p>
        <a href="/party/new"
          class="bg-violet-600 hover:bg-violet-700 text-white text-sm font-bold px-6 py-3 rounded-lg transition-colors inline-block">
          Create a party →
        </a>
      </div>
    ) : (
      <div class="flex flex-col gap-4">
        {parties.map((party, i) => {
          const summary = summaries[i];
          const isPast = new Date(party.event_date) < new Date();
          const imageUrl = party.image_key ? `${env.APP_URL}/images/${party.id}/cover` : null;
          return (
            <a href={`/manage/${party.management_token}`}
               class="group bg-white border border-zinc-100 rounded-2xl shadow-sm overflow-hidden flex hover:shadow-md transition-shadow">

              {/* Cover image or placeholder */}
              <div class="w-28 sm:w-36 flex-shrink-0 relative bg-violet-50">
                {imageUrl ? (
                  <img src={imageUrl} alt="" class="w-full h-full object-cover" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-3xl">🎊</div>
                )}
                {isPast && (
                  <div class="absolute inset-0 bg-black/30 flex items-center justify-center">
                    <span class="text-white text-[10px] font-bold uppercase tracking-wider bg-black/50 px-2 py-0.5 rounded-full">Past</span>
                  </div>
                )}
              </div>

              <div class="flex-1 px-5 py-4 min-w-0">
                <div class="flex items-start justify-between gap-3">
                  <h2 class="font-extrabold text-zinc-900 text-base leading-snug group-hover:text-violet-700 transition-colors truncate">
                    {party.title}
                  </h2>
                  <span class="text-[11px] text-zinc-400 flex-shrink-0 mt-0.5">{eventDateFmt(party.event_date)}</span>
                </div>

                {party.location && (
                  <p class="text-xs text-zinc-500 mt-0.5 truncate">📍 {party.location}</p>
                )}

                <div class="flex items-center gap-4 mt-3 flex-wrap">
                  <span class="text-xs font-semibold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full">
                    {summary.attending} attending
                  </span>
                  {summary.pending > 0 && (
                    <span class="text-xs font-semibold text-amber-600 bg-amber-50 px-2 py-0.5 rounded-full">
                      {summary.pending} pending
                    </span>
                  )}
                  {summary.headcount > 0 && (
                    <span class="text-xs text-zinc-400">{summary.headcount} total guests</span>
                  )}
                </div>
              </div>

              <div class="flex items-center pr-4 text-zinc-300 group-hover:text-violet-400 transition-colors">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</Layout>
