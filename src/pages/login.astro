---
export const prerender = false;
import { env } from 'cloudflare:workers';
import Layout from '../layouts/Layout.astro';
import { getSession } from '../lib/auth';

const sessionToken = Astro.cookies.get('wid_session')?.value;
if (sessionToken) {
  const session = await getSession(env.SESSION, sessionToken);
  if (session) return Astro.redirect('/');
}

const redirect = Astro.url.searchParams.get('redirect') ?? '/my-parties';
const sitekey = (env as any).TURNSTILE_SITE_KEY ?? '';
---

<Layout title="Sign in — whosisdown">
  <!-- explicit render mode — widget only appears after our script sets up callbacks -->
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer is:inline></script>

  <!-- Pass server vars to module script via data attributes -->
  <div id="login-config" data-redirect={redirect} data-sitekey={sitekey} hidden></div>

  <div class="min-h-[calc(100vh-56px)] flex items-center justify-center px-6 py-16">
    <div class="w-full max-w-sm">
      <div class="bg-white rounded-2xl border border-zinc-100 shadow-sm px-8 py-8">
        <div class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center text-xl mb-5">🔐</div>

        <h1 class="text-xl font-extrabold text-zinc-900 mb-1">One username. That's it.</h1>
        <p class="text-sm text-zinc-500 leading-relaxed mb-1">
          Type any username and hit Continue. If it's new, we'll create your account on the spot using a passkey — your fingerprint, Face ID, or device PIN. No password, no email verification, no separate sign-up flow.
        </p>
        <p class="text-[12px] text-zinc-400 mb-6">Returning? Same username → you're back in.</p>

        <!-- Step 1: username -->
        <div id="step-username">
          <div class="flex flex-col gap-1.5 mb-4">
            <label for="username" class="text-sm font-semibold text-zinc-700">Username</label>
            <input id="username" type="text" placeholder="yourname" autocomplete="username" spellcheck="false"
              class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow" />
          </div>

          <!-- Turnstile widget mount point -->
          <div class="mb-4 flex justify-center min-h-[65px] items-center">
            <div id="ts-widget"></div>
          </div>

          <button id="btn-continue" disabled
            class="w-full bg-violet-600 text-white font-bold py-3 rounded-lg text-[15px] transition-all opacity-50 cursor-not-allowed">
            Continue →
          </button>
          <p id="ts-hint" class="text-[11px] text-zinc-400 text-center mt-2">Waiting for verification…</p>
        </div>

        <!-- Step 2: passkey ceremony -->
        <div id="step-passkey" class="hidden text-center py-2">
          <div class="text-4xl mb-3">✋</div>
          <p class="text-sm font-semibold text-zinc-800 mb-1" id="passkey-msg">Waiting for passkey…</p>
          <p class="text-xs text-zinc-400 mb-4" id="passkey-sub"></p>
          <button id="btn-back" class="text-sm text-zinc-400 hover:text-zinc-600 transition-colors">← Back</button>
        </div>

        <div id="feedback" class="mt-3"></div>

        <div class="mt-5 pt-4 border-t border-zinc-100 text-center">
          <a href="/" class="text-sm text-zinc-400 hover:text-zinc-600 transition-colors">← Continue as guest</a>
        </div>
      </div>

      <p class="text-center text-xs text-zinc-400 mt-4 leading-relaxed">
        Signed-in accounts keep parties forever.<br>Guest parties expire after 6 months.
      </p>
    </div>
  </div>
</Layout>

<script>
  import { startRegistration, startAuthentication } from '@simplewebauthn/browser';

  const cfg          = document.getElementById('login-config') as HTMLElement;
  const redirect     = cfg.dataset.redirect ?? '/';
  const sitekey      = cfg.dataset.sitekey ?? '';

  const usernameInput = document.getElementById('username') as HTMLInputElement;
  const btnContinue  = document.getElementById('btn-continue') as HTMLButtonElement;
  const tsHint       = document.getElementById('ts-hint') as HTMLElement;
  const stepUsername = document.getElementById('step-username') as HTMLElement;
  const stepPasskey  = document.getElementById('step-passkey') as HTMLElement;
  const passkeyMsg   = document.getElementById('passkey-msg') as HTMLElement;
  const passkeySub   = document.getElementById('passkey-sub') as HTMLElement;
  const feedback     = document.getElementById('feedback') as HTMLElement;

  let turnstileToken: string | null = null;
  let widgetId: string | null = null;

  // ── Explicit Turnstile render — callbacks are closures, no globals needed ──
  function initWidget() {
    if (!window.turnstile) { setTimeout(initWidget, 50); return; }
    widgetId = window.turnstile.render('#ts-widget', {
      sitekey,
      theme: 'light',
      size: 'flexible',
      callback(token) {
        turnstileToken = token;
        btnContinue.disabled = false;
        btnContinue.classList.remove('opacity-50', 'cursor-not-allowed');
        btnContinue.classList.add('hover:bg-violet-700', 'hover:-translate-y-0.5', 'hover:shadow-lg', 'hover:shadow-violet-500/30');
        tsHint.classList.add('hidden');
      },
      'expired-callback'() {
        turnstileToken = null;
        btnContinue.disabled = true;
        btnContinue.classList.add('opacity-50', 'cursor-not-allowed');
        tsHint.textContent = 'Verification expired — please wait for it to refresh';
        tsHint.classList.remove('hidden');
      },
      'error-callback'() {
        turnstileToken = null;
        tsHint.textContent = 'Verification failed — please refresh the page';
        tsHint.classList.remove('hidden');
      },
    });
  }
  initWidget();

  function resetWidget() {
    turnstileToken = null;
    if (widgetId !== null && window.turnstile) window.turnstile.reset(widgetId);
    btnContinue.disabled = true;
    btnContinue.classList.add('opacity-50', 'cursor-not-allowed');
    tsHint.textContent = 'Waiting for verification…';
    tsHint.classList.remove('hidden');
  }

  function showError(msg) {
    feedback.innerHTML = `<div class="bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-lg">${msg}</div>`;
  }

  function resetToUsername() {
    stepPasskey.classList.add('hidden');
    stepUsername.classList.remove('hidden');
    resetWidget();
  }

  document.getElementById('btn-back').addEventListener('click', resetToUsername);

  // ── Auth flow ───────────────────────────────────────────────────────────────
  async function doAuth(username) {
    feedback.innerHTML = '';
    stepUsername.classList.add('hidden');
    stepPasskey.classList.remove('hidden');

    const loginStart = await fetch('/api/auth/login/start', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, turnstileToken }),
    });

    if (loginStart.ok) {
      passkeyMsg.textContent = `Welcome back, ${username}!`;
      passkeySub.textContent = 'Use your passkey to sign in';
      try {
        const assertion = await startAuthentication({ optionsJSON: await loginStart.json() });
        const finish = await fetch('/api/auth/login/finish', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, assertion }),
        });
        if (finish.ok) { window.location.href = redirect; return; }
        showError((await finish.json()).error || 'Sign in failed');
      } catch (e) {
        showError('Passkey cancelled or not recognised. ' + (e.message || ''));
      }

    } else if (loginStart.status === 404) {
      passkeyMsg.textContent = `Creating account for "${username}"`;
      passkeySub.textContent = 'Set up your passkey — fingerprint, Face ID, or device PIN';
      const startRes = await fetch('/api/auth/register/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, turnstileToken }),
      });
      if (!startRes.ok) {
        showError((await startRes.json()).error || 'Could not start registration');
        resetToUsername(); return;
      }
      try {
        const credential = await startRegistration({ optionsJSON: await startRes.json() });
        const finish = await fetch('/api/auth/register/finish', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, credential }),
        });
        if (finish.ok) { window.location.href = redirect; return; }
        showError((await finish.json()).error || 'Registration failed');
      } catch (e) {
        showError('Passkey setup cancelled. ' + (e.message || ''));
      }

    } else {
      showError((await loginStart.json()).error || 'Something went wrong');
    }

    resetToUsername();
  }

  btnContinue.addEventListener('click', async () => {
    const username = usernameInput.value.trim().toLowerCase();
    if (!username) { showError('Enter a username'); return; }
    if (!turnstileToken) { showError('Please wait for the verification to complete'); return; }
    await doAuth(username);
  });

  usernameInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') btnContinue.click();
  });
</script>
