---
export interface Props {
  partyId: string;
  managementToken: string;
}
const { partyId, managementToken } = Astro.props;
---

<div class="bg-white rounded-2xl border border-zinc-100 shadow-sm px-6 py-6 mt-6">
  <h3 class="text-base font-bold text-zinc-900 mb-4">Add a guest</h3>
  <form id="invite-form" class="flex flex-col gap-4">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <div class="flex flex-col gap-1.5">
        <label for="g-name" class="text-sm font-semibold text-zinc-700">Name <span class="text-violet-600">*</span></label>
        <input id="g-name" name="name" type="text" required placeholder="Alice"
          class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow" />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="g-email" class="text-sm font-semibold text-zinc-700">Email</label>
        <input id="g-email" name="email" type="email" placeholder="alice@example.com"
          class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow" />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="g-phone" class="text-sm font-semibold text-zinc-700">Phone</label>
        <input id="g-phone" name="phone" type="tel" placeholder="+1 555 000 0000"
          class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow" />
      </div>
    </div>
    <p class="text-[12px] text-zinc-400 -mt-2">Needs at least one of email or phone.</p>
    <div class="flex items-center gap-3">
      <button type="submit"
        class="bg-violet-600 hover:bg-violet-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
        Add guest
      </button>
      <p id="invite-feedback" class="text-sm text-emerald-600 font-medium"></p>
    </div>
  </form>
</div>

<script define:vars={{ partyId, managementToken }}>
  document.getElementById('invite-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type="submit"]');
    btn.textContent = 'Adding…';
    btn.disabled = true;

    const data = new FormData(form);
    const payload = {
      name: data.get('name'),
      email: data.get('email') || undefined,
      phone: data.get('phone') || undefined,
    };
    const res = await fetch(`/api/parties/${partyId}/guests`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Management-Token': managementToken },
      body: JSON.stringify(payload),
    });
    const json = await res.json();
    const fb = document.getElementById('invite-feedback');
    if (!res.ok) {
      fb.textContent = json.error;
      fb.className = 'text-sm text-red-600 font-medium';
      btn.textContent = 'Add guest';
      btn.disabled = false;
      return;
    }
    fb.textContent = `✓ ${data.get('name')} added`;
    fb.className = 'text-sm text-emerald-600 font-medium';
    form.reset();
    setTimeout(() => location.reload(), 800);
  });
</script>
