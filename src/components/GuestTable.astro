---
import type { Guest, RsvpSummary } from '../lib/db';

export interface Props {
  guests: Guest[];
  summary: RsvpSummary;
  partyId: string;
  managementToken: string;
  appUrl: string;
}
const { guests, summary, partyId, managementToken, appUrl } = Astro.props;
---

<!-- RSVP Summary stats -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
  <div class="bg-white border border-zinc-100 rounded-xl px-4 py-4 text-center shadow-sm">
    <span class="block text-3xl font-black text-emerald-600 leading-none mb-1">{summary.attending}</span>
    <span class="text-[12px] text-zinc-400 font-medium">Attending</span>
  </div>
  <div class="bg-white border border-zinc-100 rounded-xl px-4 py-4 text-center shadow-sm">
    <span class="block text-3xl font-black text-violet-600 leading-none mb-1">{summary.headcount}</span>
    <span class="text-[12px] text-zinc-400 font-medium">Total guests</span>
  </div>
  <div class="bg-white border border-zinc-100 rounded-xl px-4 py-4 text-center shadow-sm">
    <span class="block text-3xl font-black text-amber-600 leading-none mb-1">{summary.pending}</span>
    <span class="text-[12px] text-zinc-400 font-medium">Pending</span>
  </div>
  <div class="bg-white border border-zinc-100 rounded-xl px-4 py-4 text-center shadow-sm">
    <span class="block text-3xl font-black text-red-500 leading-none mb-1">{summary.declined}</span>
    <span class="text-[12px] text-zinc-400 font-medium">Declined</span>
  </div>
</div>

<!-- Actions -->
<div class="flex gap-2 mb-4 flex-wrap">
  <button id="send-all-btn"
    data-party-id={partyId} data-token={managementToken}
    class="bg-violet-600 hover:bg-violet-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
    Send invites to pending
  </button>
  <button id="export-btn"
    data-party-id={partyId} data-token={managementToken}
    class="border border-zinc-200 hover:border-zinc-400 text-zinc-700 text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
    Export CSV
  </button>
</div>

{guests.length === 0 ? (
  <div class="bg-white border border-zinc-100 rounded-xl p-10 text-center shadow-sm">
    <p class="text-zinc-400 text-sm">No guests yet. Add some below.</p>
  </div>
) : (
  <div class="bg-white border border-zinc-100 rounded-xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-zinc-100">
            <th class="text-left px-4 py-3 text-[12px] font-semibold text-zinc-400 uppercase tracking-wide">Name</th>
            <th class="text-left px-4 py-3 text-[12px] font-semibold text-zinc-400 uppercase tracking-wide">Contact</th>
            <th class="text-left px-4 py-3 text-[12px] font-semibold text-zinc-400 uppercase tracking-wide">Status</th>
            <th class="text-left px-4 py-3 text-[12px] font-semibold text-zinc-400 uppercase tracking-wide">Guests</th>
            <th class="text-left px-4 py-3 text-[12px] font-semibold text-zinc-400 uppercase tracking-wide">Dietary</th>
            <th class="text-left px-4 py-3 text-[12px] font-semibold text-zinc-400 uppercase tracking-wide">Link</th>
          </tr>
        </thead>
        <tbody>
          {guests.map(g => (
            <tr class="border-b border-zinc-50 hover:bg-zinc-50 transition-colors">
              <td class="px-4 py-3 font-semibold text-zinc-800">{g.name}</td>
              <td class="px-4 py-3 text-zinc-500 max-w-[180px] truncate">{g.email || g.phone}</td>
              <td class="px-4 py-3">
                {g.status === 'attending' && (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-semibold bg-emerald-100 text-emerald-700">attending</span>
                )}
                {g.status === 'declined' && (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-semibold bg-red-100 text-red-700">declined</span>
                )}
                {g.status === 'pending' && (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-semibold bg-amber-100 text-amber-700">pending</span>
                )}
              </td>
              <td class="px-4 py-3 text-zinc-600">{g.guest_count}</td>
              <td class="px-4 py-3 text-zinc-500">{g.dietary_notes ?? '—'}</td>
              <td class="px-4 py-3">
                <a href={`${appUrl}/invite/${g.rsvp_token}`} target="_blank"
                   class="text-violet-600 hover:text-violet-800 font-medium transition-colors">
                  Open ↗
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
)}

<script>
  document.getElementById('export-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const { partyId, token } = btn.dataset;
    const res = await fetch(`/api/parties/${partyId}/export`, {
      headers: { 'X-Management-Token': token! },
    });
    const blob = await res.blob();
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'guests.csv'; a.click();
    URL.revokeObjectURL(url);
  });

  document.getElementById('send-all-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const { partyId, token } = btn.dataset;
    btn.disabled = true;
    btn.textContent = 'Sending…';
    const res = await fetch(`/api/parties/${partyId}/invite`, {
      method: 'POST',
      headers: { 'X-Management-Token': token!, 'Content-Type': 'application/json' },
      body: '{}',
    });
    const json = await res.json();
    btn.textContent = `✓ ${json.sent} sent`;
    setTimeout(() => location.reload(), 1400);
  });
</script>
