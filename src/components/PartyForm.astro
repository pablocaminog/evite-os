---
export interface Props {
  error?: string;
}
const { error } = Astro.props;
---

<form id="party-form" class="flex flex-col gap-5">
  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-lg">{error}</div>
  )}

  <div class="flex flex-col gap-1.5">
    <label for="title" class="text-sm font-semibold text-zinc-700">Party name <span class="text-violet-600">*</span></label>
    <input id="title" name="title" type="text" required placeholder="Dino Birthday Party"
      class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow" />
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="organizer_name" class="text-sm font-semibold text-zinc-700">Your name <span class="text-violet-600">*</span></label>
    <input id="organizer_name" name="organizer_name" type="text" required placeholder="Pablo"
      class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow" />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="flex flex-col gap-1.5">
      <label for="organizer_email" class="text-sm font-semibold text-zinc-700">Your email</label>
      <input id="organizer_email" name="organizer_email" type="email" placeholder="you@example.com"
        class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow" />
      <p class="text-[12px] text-zinc-400">Used for dashboard link recovery</p>
    </div>
    <div class="flex flex-col gap-1.5">
      <label for="organizer_phone" class="text-sm font-semibold text-zinc-700">Your phone</label>
      <input id="organizer_phone" name="organizer_phone" type="tel" placeholder="+1 555 000 0000"
        class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow" />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="flex flex-col gap-1.5">
      <label for="event_date" class="text-sm font-semibold text-zinc-700">Date &amp; time <span class="text-violet-600">*</span></label>
      <input id="event_date" name="event_date" type="datetime-local" required
        class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow" />
    </div>
    <div class="flex flex-col gap-1.5">
      <label for="rsvp_deadline" class="text-sm font-semibold text-zinc-700">RSVP deadline</label>
      <input id="rsvp_deadline" name="rsvp_deadline" type="datetime-local"
        class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow" />
    </div>
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="location" class="text-sm font-semibold text-zinc-700">Location</label>
    <input id="location" name="location" type="text" placeholder="123 Park Ave"
      class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow" />
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="description" class="text-sm font-semibold text-zinc-700">Details / message</label>
    <textarea id="description" name="description" rows="3"
      placeholder="Come dressed as your favourite dinosaur!"
      class="w-full px-3.5 py-2.5 border border-zinc-200 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition-shadow resize-none"></textarea>
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="image" class="text-sm font-semibold text-zinc-700">Cover image</label>
    <!-- Preview -->
    <div id="img-preview-wrap" class="hidden relative rounded-xl overflow-hidden aspect-[2.4/1]">
      <img id="img-preview" src="" alt="Cover preview" class="w-full h-full object-cover" />
      <label for="image" class="absolute inset-0 flex items-center justify-center bg-black/40 opacity-0 hover:opacity-100 transition-opacity cursor-pointer text-white text-sm font-semibold">
        Change image
      </label>
    </div>
    <!-- Drop zone (hidden when preview shown) -->
    <label for="image" id="drop-zone" class="border-2 border-dashed border-zinc-200 rounded-xl px-4 py-6 text-center hover:border-violet-300 transition-colors cursor-pointer block">
      <div class="text-2xl mb-2">🖼</div>
      <p class="text-sm text-zinc-500 mb-0.5">Drag &amp; drop or <span class="text-violet-600 font-semibold">browse</span></p>
      <p class="text-[12px] text-zinc-400">JPEG, PNG, WebP — max 5MB</p>
      <p class="text-[12px] text-zinc-400 mt-1">
        Tip: generate with AI —
        <a href="https://github.com/pablocaminog/evite-os/blob/main/docs/image-generation-prompts.md"
           target="_blank" class="text-violet-600 hover:underline" onclick="event.stopPropagation()">prompt guide →</a>
      </p>
    </label>
    <input id="image" name="image" type="file" accept="image/jpeg,image/png,image/webp" class="hidden" />
  </div>

  <button type="submit"
    class="w-full bg-violet-600 hover:bg-violet-700 text-white font-bold py-3.5 rounded-lg text-[15px] transition-all hover:-translate-y-0.5 hover:shadow-lg hover:shadow-violet-500/30 mt-2">
    Create party →
  </button>
</form>

<script>
  const imageInput = document.getElementById('image') as HTMLInputElement;
  const dropZone = document.getElementById('drop-zone')!;
  const previewWrap = document.getElementById('img-preview-wrap')!;
  const previewImg = document.getElementById('img-preview') as HTMLImageElement;

  imageInput?.addEventListener('change', () => {
    const file = imageInput.files?.[0];
    if (!file) return;
    const url = URL.createObjectURL(file);
    previewImg.src = url;
    previewWrap.classList.remove('hidden');
    dropZone.classList.add('hidden');
  });
</script>
